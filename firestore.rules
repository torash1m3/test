rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Профили пользователей
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId
                   && (!("pcSpecs" in request.resource.data) || request.resource.data.pcSpecs.size() <= 2000)
                   && (!("displayName" in request.resource.data) || request.resource.data.displayName.size() <= 50);
    }

    // Сборки
    match /users/{userId}/builds/{buildId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // База комплектующих
    match /components/{category}/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Репорты
    match /reports/{reportId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null 
                    && request.resource.data.componentName.size() <= 100
                    && request.resource.data.description.size() <= 1000;
      allow update, delete: if false;
    }

    // Форум — посты
    match /forum/{postId} {
      allow read: if true;
      
      allow create: if request.auth != null 
                    && request.resource.data.title.size() <= 100
                    && request.resource.data.content.size() <= 5000;
      
      // Обновлять может либо автор (разрешаем всё для будущих эдитов), 
      // либо любой авторизованный юзер, но СТРОГО только поля лайков и счетчика комментов.
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.authorId ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['commentCount', 'likedBy'])
      );
      
      allow delete: if request.auth != null && request.auth.uid == resource.data.authorId;

      // Подколлекция комментариев
      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null 
                      && request.resource.data.content.size() <= 2000;
        allow update, delete: if request.auth != null && request.auth.uid == resource.data.authorId;
      }
    }
  }
}

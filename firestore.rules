rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // ИСПОЛЬЗУЕМ CUSTOM CLAIMS вместо медленных и дорогих get() запросов
      return isSignedIn() && request.auth.token.role == 'admin';
    }

    function isModerator() {
      // ИСПОЛЬЗУЕМ CUSTOM CLAIMS
      return isSignedIn() && request.auth.token.role == 'moderator';
    }

    function canModerate() {
      return isAdmin() || isModerator();
    }

    function isValidRole(role) {
      return role == 'user' || role == 'moderator' || role == 'admin';
    }

    function currentUserRole() {
      return ('role' in request.auth.token) ? request.auth.token.role : 'user';
    }

    // Проверяем обязательные поля через hasAll и необязательные через hasOnly
    function validProfilePayload(data) {
      let requiredFields = [
        'uid','email','displayName','nickname','avatarUrl',
        'pcSpecs','bio','socialLinks','role','createdAt','updatedAt'
      ];
      return data.keys().hasAll(requiredFields)
             && data.keys().hasOnly(requiredFields)
             && data.uid is string
             && data.email is string
             && data.displayName is string
             && data.nickname is string
             && data.avatarUrl is string
             && data.pcSpecs is string
             && data.bio is string
             && data.role is string
             && isValidRole(data.role)
             && data.uid.size() > 0
             && data.email.size() <= 254
             && data.displayName.size() <= 50
             && data.nickname.size() <= 30
             && data.avatarUrl.size() <= 500
             && data.pcSpecs.size() <= 2000
             && data.bio.size() <= 500;
    }

    function validPublicProfilePayload(data) {
      let requiredFields = [
        'uid','displayName','nickname','avatarUrl',
        'pcSpecs','bio','role','socialLinks','createdAt','updatedAt'
      ];
      return data.keys().hasAll(requiredFields)
             && data.keys().hasOnly(requiredFields)
             && data.uid is string
             && data.displayName is string
             && data.nickname is string
             && data.avatarUrl is string
             && data.pcSpecs is string
             && data.bio is string
             && data.role is string
             && isValidRole(data.role)
             && data.uid.size() > 0
             && data.displayName.size() <= 50
             && data.nickname.size() <= 30
             && data.avatarUrl.size() <= 500
             && data.pcSpecs.size() <= 2000
             && data.bio.size() <= 500;
    }

    // ══════════════════════════════════════════
    // Профили пользователей
    // ══════════════════════════════════════════
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();

      // Создание профиля — только свой, с дефолтной ролью
      allow create: if isOwner(userId)
                    && validProfilePayload(request.resource.data)
                    && request.resource.data.uid == userId
                    && request.resource.data.role == 'user';

      // Обновление — только свой, нельзя менять role/uid/email.
      // Админ может менять только роль и только на разрешённое значение.
      allow update: if (isOwner(userId)
                    && validProfilePayload(request.resource.data)
                    && request.resource.data.role == resource.data.role
                    && request.resource.data.uid == resource.data.uid
                    && request.resource.data.email == resource.data.email)
                    || (
                      isAdmin()
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['role'])
                      && isValidRole(request.resource.data.role)
                    );

      allow delete: if false;
    }

    // ══════════════════════════════════════════
    // Публичные профили без email и приватных полей
    // ══════════════════════════════════════════
    match /publicProfiles/{userId} {
      allow read: if true;

      allow create: if isOwner(userId)
                    && validPublicProfilePayload(request.resource.data)
                    && request.resource.data.uid == userId
                    && request.resource.data.role == currentUserRole();

      allow update: if (
                      isOwner(userId)
                      && validPublicProfilePayload(request.resource.data)
                      && request.resource.data.uid == resource.data.uid
                      && request.resource.data.role == resource.data.role
                    )
                    || (
                      isAdmin()
                      && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['role'])
                      && isValidRole(request.resource.data.role)
                    );

      allow delete: if false;
    }

    // ══════════════════════════════════════════
    // Сборки
    // ══════════════════════════════════════════
    match /users/{userId}/builds/{buildId} {
      allow read, write: if isOwner(userId);
    }

    // ══════════════════════════════════════════
    // База комплектующих (read-only)
    // ══════════════════════════════════════════
    match /components/{category}/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // ══════════════════════════════════════════
    // Репорты
    // ══════════════════════════════════════════
    match /reports/{reportId} {
      allow read: if isSignedIn() && (
        resource.data.authorId == request.auth.uid || canModerate()
      );
      allow create: if isSignedIn()
                    && request.resource.data.keys().hasAll([
                      'componentName','category','description','status',
                      'authorId','authorName','createdAt'
                    ])
                    && request.resource.data.keys().hasOnly([
                      'componentName','category','description','status',
                      'authorId','authorName','createdAt'
                    ])
                    && request.resource.data.authorId == request.auth.uid
                    && request.resource.data.componentName is string
                    && request.resource.data.category is string
                    && request.resource.data.category.size() > 0
                    && request.resource.data.category.size() <= 30
                    && request.resource.data.componentName.size() <= 100
                    && request.resource.data.description is string
                    && request.resource.data.description.size() <= 1000
                    && request.resource.data.authorName is string
                    && request.resource.data.authorName.size() > 0
                    && request.resource.data.authorName.size() <= 100
                    && request.resource.data.status == 'pending';
      allow update: if canModerate()
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
                    && (
                      request.resource.data.status == 'pending'
                      || request.resource.data.status == 'reviewed'
                      || request.resource.data.status == 'rejected'
                      || request.resource.data.status == 'done'
                    );
      allow delete: if false;
    }

    // ══════════════════════════════════════════
    // Форум — посты
    // ══════════════════════════════════════════
    match /forum/{postId} {
      function isValidSection(section) {
        return section == 'news' || section == 'chat';
      }

      function isValidLikeUpdate() {
        return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likedBy'])
               && request.resource.data.likedBy is list
               && request.resource.data.likedBy.size() <= 1000
               && (
                 // Обработка arrayUnion() на клиенте (добавление лайка)
                 (
                   !resource.data.likedBy.hasAny([request.auth.uid])
                   && request.resource.data.likedBy.size() == resource.data.likedBy.size() + 1
                   && request.resource.data.likedBy.hasAll(resource.data.likedBy)
                   && request.resource.data.likedBy.hasAll([request.auth.uid])
                 )
                 ||
                 // Обработка arrayRemove() на клиенте (удаление лайка)
                 (
                   resource.data.likedBy.hasAny([request.auth.uid])
                   && !request.resource.data.likedBy.hasAny([request.auth.uid])
                   && request.resource.data.likedBy.size() == resource.data.likedBy.size() - 1
                   && resource.data.likedBy.hasAll(request.resource.data.likedBy)
                 )
               );
      }

      function isValidCommentCountUpdate() {
        // Подтверждение вызова FieldValue.increment(1) со стороны клиента
        return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['commentCount'])
               && request.resource.data.commentCount == resource.data.commentCount + 1;
      }

      allow read: if true;

      allow create: if isSignedIn()
                    && request.resource.data.keys().hasAll([
                      'section','title','content','authorId','authorName',
                      'authorAvatar','commentCount','likedBy','createdAt'
                    ])
                    && request.resource.data.authorId == request.auth.uid
                    && request.resource.data.authorName is string
                    && request.resource.data.authorName.size() > 0
                    && request.resource.data.authorName.size() <= 100
                    && request.resource.data.authorAvatar is string
                    && request.resource.data.authorAvatar.size() <= 500
                    && isValidSection(request.resource.data.section)
                    && request.resource.data.title is string
                    && request.resource.data.title.size() <= 100
                    && request.resource.data.content is string
                    && request.resource.data.content.size() > 0
                    && request.resource.data.content.size() <= 5000
                    && request.resource.data.likedBy is list
                    && request.resource.data.likedBy.size() == 0
                    && request.resource.data.commentCount == 0;

      allow update: if isSignedIn() && (
        isValidLikeUpdate() || isValidCommentCountUpdate()
      );

      allow delete: if isSignedIn() && (request.auth.uid == resource.data.authorId || canModerate());

      // ── Подколлекция комментариев ──
      match /comments/{commentId} {
        allow read: if true;
        allow create: if isSignedIn()
                      && request.resource.data.keys().hasAll([
                        'content','authorId','authorName','authorAvatar','createdAt'
                      ])
                      && request.resource.data.authorId == request.auth.uid
                      && request.resource.data.authorName is string
                      && request.resource.data.authorName.size() > 0
                      && request.resource.data.authorName.size() <= 100
                      && request.resource.data.authorAvatar is string
                      && request.resource.data.authorAvatar.size() <= 500
                      && request.resource.data.content is string
                      && request.resource.data.content.size() > 0
                      && request.resource.data.content.size() <= 2000;
        allow update: if false;
        allow delete: if isSignedIn() && (request.auth.uid == resource.data.authorId || canModerate());
      }
    }
  }
}

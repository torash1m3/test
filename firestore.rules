rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Профили пользователей — читать может любой, писать только владелец
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Сборки — читать может любой, писать только владелец
    match /users/{userId}/builds/{buildId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // База комплектующих — читать может любой, писать никто (только админ через консоль)
    match /components/{category}/{docId} {
      allow read: if true;
      allow write: if false;
    }

    // Репорты о недостающих комплектующих — создавать может любой авторизованный
    match /reports/{reportId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // Форум — посты и комментарии
    match /forum/{postId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.authorId;
    }
  }
}
